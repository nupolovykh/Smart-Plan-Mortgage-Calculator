{
    "name": "phpcalculator",
    "remoteUser": "vscode",
    "image": "mcr.microsoft.com/devcontainers/php:8.3",
    "postCreateCommand": "bash .devcontainer/post-create.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "anthropic.claude-code",
                "xdebug.php-debug",
                "bmewburn.vscode-intelephense-client",
                "dbaeumer.vscode-eslint",
                "mrmlnc.vscode-apache"
            ]
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/node:2.1.0": {},
        "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
    },
    "mounts": [
        "source=claude-config,target=/home/vscode/.claude,type=volume",
        "source=copilot-config,target=/home/vscode/.copilot,type=volume"
    ]
}