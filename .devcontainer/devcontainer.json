{
    "name": "phpcalculator",
    "remoteUser": "vscode",
    "image": "mcr.microsoft.com/devcontainers/php:8.3",
    "postCreateCommand": "bash .devcontainer/post-create.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "anthropic.claude-code",
                "xdebug.php-debug",
                "bmewburn.vscode-intelephense-client",
                "dbaeumer.vscode-eslint",
                "mrmlnc.vscode-apache"
            ],
            "settings": {
                "terminal.integrated.profiles.linux": {
                    "Claude Code": {
                        "path": "bash",
                        "args": ["-c", "exec sudo -u claudeme -i"],
                        "icon": "terminal-bash",
                        "color": "terminal.ansiYellow"
                    }
                }
            }
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/node:2.1.0": {},
        "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
    },
    "forwardPorts": [8000, 5173],
    "portsAttributes": {
        "8000": { "label": "Backend (php api)", "onAutoForward": "silent" },
        "5173": { "label": "Frontend (vite)", "onAutoForward": "notify" }
    },
    "mounts": [
        "source=claude-vscode,target=/home/vscode/.claude,type=volume",
        "source=claude-cli,target=/home/claudeme/.claude,type=volume",
        "source=gh-shared,target=/home/claudeme/.config/gh,type=volume"
    ],
    "containerEnv": {
        "DISABLE_AUTOUPDATER": "1",
        "CLAUDE_CODE_HOST_TOKEN": "${localEnv:CLAUDE_CODE_OAUTH_TOKEN}"
    }
}